generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AllowedEmail {
  id        String   @id @default(uuid())
  email     String
  name      String?
  position  String?  // New: Job Title / Role
  category  String?  // New: Core Team, Tech Blog, Graphic Design
  profile   String?  // Preserving legacy field
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([email, category])
}

model Template {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String   
  config    String   // JSON string storing layout config
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Certificate {
  id        String   @id @default(uuid())
  uniqueId  String   @unique 
  email     String
  name      String
  position  String?  // New
  category  String?  // New
  profile   String?  // Preserving legacy field
  issuedAt  DateTime @default(now())
  templateId String
  revoked   Boolean  @default(false)
}
