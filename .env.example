# ============================================================
# Supabase Configuration (Required for production)
# ============================================================
# Get these values from your Supabase project settings
# Dashboard: https://app.supabase.com/

# Main dashboard project (pdqytkydmbvepwiddwzb)
VITE_SUPABASE_URL=https://pdqytkydmbvepwiddwzb.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Alternative (if using ANON_KEY instead of PUBLISHABLE_KEY)
# VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Certificate project (separate — NEVER TOUCH)
VITE_CERT_SUPABASE_URL=https://lmjvkfyabdcainqkmmwt.supabase.co
VITE_CERT_SUPABASE_KEY=your_cert_key_here

# ============================================================
# Optional: Gemini API (for AI features)
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Instructions for Vercel deployment:
# 1. Copy all VITE_* variables to Vercel Environment Variables
# 2. Set them for all environments (Production, Preview, Development)
# 3. Redeploy after adding environment variables
# ============================================================
